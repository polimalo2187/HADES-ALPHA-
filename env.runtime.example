# ==============================
# Base común
# ==============================
ENVIRONMENT=production
MONGODB_URI=mongodb+srv://USER:PASS@HOST/?retryWrites=true&w=majority
DATABASE_NAME=hades_db
BOT_TOKEN=123456:telegram-token

# ==============================
# Web / MiniApp
# ==============================
ENABLE_MINI_APP_SERVER=true
APP_RUNTIME_ROLE=web
MINI_APP_URL=https://tu-dominio.com/miniapp
MINI_APP_SESSION_SECRET=cambia-esto-por-un-secreto-largo
MINI_APP_CORS_ORIGINS=https://tu-dominio.com

# ==============================
# Dev auth (solo local / test)
# ==============================
MINI_APP_ALLOW_DEV_AUTH=false
MINI_APP_DEV_USER_ID=

# ==============================
# Scheduler
# ==============================
SCHEDULER_CHECK_INTERVAL=300
SCHEDULER_BATCH_SIZE=100
SCHEDULER_EVALUATION_LIMIT=200
SCHEDULER_STATS_REFRESH_EVERY_LOOPS=3
SCHEDULER_HISTORY_BACKFILL_EVERY_LOOPS=6

# ==============================
# Retención
# ==============================
BASE_SIGNALS_RETENTION_DAYS=180
USER_SIGNALS_RETENTION_DAYS=45
SIGNAL_RESULTS_RETENTION_DAYS=365
SIGNAL_HISTORY_RETENTION_DAYS=730

# ==============================
# Observabilidad (opcionales)
# ==============================
# HEALTH_DEFAULT_STALE_AFTER_SECONDS=300
# HEALTH_MINIAPP_STALE_AFTER_SECONDS=180
# HEALTH_BOT_STALE_AFTER_SECONDS=180
# HEALTH_SCANNER_STALE_AFTER_SECONDS=240
# HEALTH_SCHEDULER_STALE_AFTER_SECONDS=900


# ==============================
# Scanner (señales)
# ==============================
# Importante: la estrategia usa EMA200. Necesitas suficiente histórico para evitar NaNs.
SCANNER_KLINE_LIMIT_5M=260
SCANNER_KLINE_LIMIT_15M=260
SCANNER_KLINE_LIMIT_1H=260

# Control de carga hacia Binance (evita bans por 429/418)
SCANNER_SYMBOL_CONCURRENCY=24
SCANNER_MAX_REQUESTS_PER_SECOND=8
SCANNER_MAX_BURST=16
REQUEST_MAX_RETRIES=4
REQUEST_RETRY_BASE_SLEEP=0.6

# Cache MTF: 15M/1H se reutilizan dentro del mismo bucket de vela.
# Esto mantiene 5M fresco en cada ciclo y evita refetch completo del contexto superior.
SCANNER_ENABLE_HTF_CACHE=true
SCANNER_5M_CACHE_SECONDS=0

# Si necesitas serializar requests (no recomendado salvo emergencia)
# SCANNER_FORCE_REQUEST_DELAY=true
# REQUEST_DELAY=0.2

PREMIUM_RAW_SCORE_MIN=80
PLUS_RAW_SCORE_MIN=74
FREE_RAW_SCORE_MIN=66

# Ventanas de señal breakout + reset
# entry_wait: cuánto tiempo puede esperar la señal a que toque la entrada
# market_validity: sigue controlado por MIN/MAX_SIGNAL_VALIDITY_MINUTES en app/signals.py
MIN_ENTRY_WAIT_MINUTES=15
MAX_ENTRY_WAIT_MINUTES=60
ENTRY_WAIT_BUFFER_MINUTES=3

# Guardas anti-señal tardía
# Si el precio ya avanzó demasiado desde la entrada modelo, no se envía la alerta pendiente.
PENDING_ENTRY_MAX_PROGRESS_TO_TP1_PCT=18
PENDING_ENTRY_MAX_R_PROGRESS=0.25

# Zona de entrada adaptativa (en vez de un 0.15% fijo demasiado estrecho)
ENTRY_ZONE_MIN_PCT=0.0015
ENTRY_ZONE_MAX_PCT=0.0035
ENTRY_ZONE_RISK_FRACTION=0.22
